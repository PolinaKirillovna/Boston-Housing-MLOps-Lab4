# Plaintext TEMPLATE for the Ansible Vault secrets file (committed as a guide).
#
# Real secrets live in the ENCRYPTED file secrets/secrets.yml. To create it:
#   1) cp secrets/secrets.yml.example secrets/secrets.yml
#   2) put real values into secrets/secrets.yml
#   3) ansible-vault encrypt secrets/secrets.yml --vault-password-file secrets/.vault_pass
#
# After step 3 secrets/secrets.yml is encrypted ($ANSIBLE_VAULT...) and safe to commit.
MSSQL_PASSWORD: CHANGE_ME_strong_password
JWT_SECRET_KEY: CHANGE_ME_long_random_secret
